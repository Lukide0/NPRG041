# Project information
PROJECT_NAME = "koterm"
PROJECT_NUMBER = "1.0"
PROJECT_BRIEF = "Koterm is a C++ library for creating static user interfaces (UI) in terminal environments."

# Source directories
RECURSIVE = YES
INPUT = ./include/koterm ./src README.md

# Output directory
OUTPUT_DIRECTORY = ./docs/doxygen
CREATE_SUBDIRS = YES
CREATE_SUBDIRS_LEVEL = 8
OUTPUT_LANGUAGE = English

# Settings
DOXYFILE_ENCODING = UTF-8

JAVADOC_AUTOBRIEF = YES
MULTILINE_CPP_IS_BRIEF = YES

EXTRACT_ALL = YES
EXTRACT_PRIVATE = YES
EXTRACT_STATIC = YES

EXCLUDE = ./tests,./examples
EXCLUDE_SYMBOLS = doctest::*

ENABLE_PREPROCESSING = YES
MACRO_EXPANSION = YES
EXPAND_ONLY_PREDEF = YES
PREDEFINED = "DEFINE_SYS_COLOR(name, id)=static constexpr auto SYS_##name = Color::from_code(id)"

GENERATE_LATEX = NO

MARKDOWN_SUPPORT = YES
USE_MDFILE_AS_MAINPAGE = README.md

# Diagrams
HAVE_DOT = YES
CALL_GRAPH = YES
CALLER_GRAPH = YES

# Style
GENERATE_TREEVIEW = YES
DISABLE_INDEX = NO
FULL_SIDEBAR = NO
HTML_EXTRA_STYLESHEET = ./vendor/doxygen-awesome/doxygen-awesome.css
HTML_COLORSTYLE = LIGHT
